generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobType {
  TEXT_TO_VIDEO
  IMAGE_TO_VIDEO
  TEXT_TO_IMAGE
  IMAGE_UPSCALE
}

enum AIProvider {
  KLING
  RUNWAY
  VEO
  STABILITY
  OPENAI
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum PaymentMethod {
  QRIS
  VA
  EWALLET
  CRYPTO
}

enum PaymentProvider {
  XENDIT
  MIDTRANS
  MANUAL
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum LedgerReason {
  TOPUP
  GENERATE_VIDEO
  GENERATE_IMAGE
  REFUND
  ADMIN_ADJUSTMENT
  BONUS
}

enum Currency {
  IDR
  USD
}

enum UserRole {
  USER
  ADMIN
}

enum ReferenceType {
  PAYMENT
  MEDIA_JOB
  MANUAL
  BONUS
}

// --- MODELS ---
model User {
  id              String      @id @default(uuid())
  telegramId      BigInt      @unique @map("telegram_id")
  username        String?
  firstName       String?     @map("first_name")
  lastName        String?     @map("last_name")
  languageCode    String?     @map("language_code")
  role            UserRole    @default(USER)
  creditBalance   Int         @default(0) @map("credit_balance")
  isActive        Boolean     @default(true) @map("is_active")
  deletedAt       DateTime?   @map("deleted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  mediaJobs       MediaJob[]
  ledgers         CreditLedger[]
  payments        PaymentTransaction[]

  @@index([telegramId])
  @@map("users")
}

model CreditLedger {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  amount          Int
  balanceBefore   Int           @map("balance_before")
  balanceAfter    Int           @map("balance_after")
  type            LedgerType
  reason          LedgerReason
  note            String?
  referenceType   ReferenceType @map("reference_type")
  referenceId     String?       @map("reference_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  user            User          @relation(fields: [userId], references: [id])
  @@index([userId])
  @@map("credit_ledgers")
}

model MediaJob {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  provider        AIProvider
  type            JobType
  prompt          String        @db.Text
  status          JobStatus     @default(PENDING)
  providerJobId   String?       @unique @map("provider_job_id")
  providerCost    Decimal?      @default(0) @db.Decimal(10, 4) @map("provider_cost")
  costCurrency    Currency      @default(USD) @map("cost_currency")
  resultUrl       String?       @map("result_url")
  metadata        Json?
  errorMessage    String?       @map("error_message")
  startedAt       DateTime?     @map("started_at")
  completedAt     DateTime?     @map("completed_at")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user            User          @relation(fields: [userId], references: [id])
  @@index([userId, status, createdAt])
  @@map("media_jobs")
}

model PaymentTransaction {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  amount            Int
  currency          Currency        @default(IDR)
  creditsPurchased  Int             @map("credits_purchased")
  status            PaymentStatus
  paymentMethod     PaymentMethod   @map("payment_method")
  paymentProvider   PaymentProvider @map("payment_provider")
  externalReference String?         @unique @map("external_reference")
  paidAt            DateTime?       @map("paid_at")
  expiredAt         DateTime        @map("expired_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user              User            @relation(fields: [userId], references: [id])
  @@index([userId, status])
  @@map("payment_transactions")
}