datasource db {
  provider = "postgresql"
  // Baris url = env("DATABASE_URL") WAJIB DIHAPUS di Prisma 7 karena sudah ada di prisma.config.ts
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
}

enum JobStatus {
  PENDING
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  TOPUP
  DEDUCT
  REFUND
  BONUS
}

model User {
  id            String              @id @default(uuid())
  telegramId    BigInt              @unique @map("telegram_id")
  username      String?
  firstName     String?             @map("first_name")
  creditBalance Int                 @default(0) @map("credit_balance")
  status        UserStatus          @default(ACTIVE)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  orders        Order[]
  mediaJobs     MediaJob[]
  transactions  CreditTransaction[]

  @@map("users")
}

model Order {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  paymentRef   String      @unique @map("payment_ref")
  amount       Decimal     @db.Decimal(12, 2)
  currency     String      @default("IDR")
  method       String      @default("QRIS")
  status       OrderStatus @default(PENDING)
  creditAmount Int         @map("credit_amount")
  qrString     String?     @map("qr_string") @db.Text
  gatewayTrxId String?     @map("gateway_trx_id")
  rawCallback  Json?       @map("raw_callback")
  expiredAt    DateTime    @map("expired_at")
  paidAt       DateTime?   @map("paid_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  user         User        @relation(fields: [userId], references: [id])

  @@map("orders")
}

model MediaJob {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  providerId    String    @map("provider_id")
  providerJobId String?   @map("provider_job_id")
  type          String
  inputParams   Json      @map("input_params")
  prompt        String    @db.Text
  status        JobStatus @default(PENDING)
  creditCost    Int       @map("credit_cost")
  retryCount    Int       @default(0) @map("retry_count")
  errorMessage  String?   @map("error_message") @db.Text
  submittedAt   DateTime? @map("submitted_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation(fields: [userId], references: [id])

  @@map("media_jobs")
}

model CreditTransaction {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  amount        Int
  type          TransactionType
  referenceType String          @map("reference_type")
  referenceId   String          @map("reference_id")
  balanceAfter  Int             @map("balance_after")
  createdAt     DateTime        @default(now()) @map("created_at")
  user          User            @relation(fields: [userId], references: [id])

  @@map("credit_transactions")
}

model ApiKey {
  id           String   @id @default(uuid())
  name         String
  encryptedKey String   @map("encrypted_key") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("api_keys")
}